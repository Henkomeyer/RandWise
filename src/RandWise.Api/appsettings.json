{
  "Persistence": {
    "ConnectionString": "Data Source=randwise.db"
  },
  "Jwt": {
    "Issuer": "RandWise",
    "Audience": "RandWise",
    "SigningKey": "replace-with-environment-secret-at-least-32-chars",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 30
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
